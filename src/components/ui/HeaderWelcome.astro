<header class="header-welcome">
  <video 
    autoplay 
    muted 
    loop 
    playsinline
    class="bg-video"
  >
    <source src="/videos/background-video.mp4" type="video/mp4" />
    Tu navegador no soporta vídeos de fondo.
  </video>

  <div>
    <h1>
      <span class="reveal-left">M</span>
      <div>
        <div class="reveal-top">&nbsp; &nbsp; SOMOS</div>
        <div class="reveal-right">ARKETING</div>
      </div>
    </h1>
    <h4>VENDEMOS RESULTADOS</h4>
    <a class="tp-contact" href="/contact"
      >CONTACTA CON NOSOTROS</a
    >
  </div>
  <a class="tp-works" href="#how-works"><span>↓</span>Scroll</a>
</header>
<style>
@font-face {
  font-family: "Great Vibes";
  src: url("../../assets/fonts/GreatVibes-Regular.ttf") format("truetype");
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}

.header-welcome {
  position: relative;
  color: #fff;
  width: 100%;
  height: 100vh;
  margin-bottom: 100px;
}

/* Works link */
.header-welcome .tp-works {
  color: var(--color-white);
  text-decoration: none;
  position: absolute;
  left: 3%;
  top: 90%;
  display: flex;
  gap: 4px;
  cursor: pointer;
  font-size: 3rem;
  user-select: none;
  transition: all 0.5s ease-in;
  opacity: 0.8;
}

.header-welcome .tp-works:hover {
  transform: translateY(11px);
  opacity: 1;
}

/* Background video */
.header-welcome video {
  position: absolute;
  z-index: -1;
  object-fit: cover;
  height: 100vh;
  width: 100%;
}

/* Content wrapper */
.header-welcome > div {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  position: relative;
  top: 25%;
}

/* Title */
.header-welcome h1 {
  font-size: 8rem;
  margin: 10px;
  display: flex;
  align-items: center;
  gap: 40px;
}

.header-welcome h1 span {
  font-family: "Great Vibes", cursive;
  font-size: 20rem;
  font-weight: 200;
}

/* Subtitle */
.header-welcome h4 {
  font-size: larger;
  color: var(--subtitle-color);
}

/* Contact button */
.header-welcome .tp-contact {
  width: 280px;
  height: 40px;
  border: none;
  background-color: var(--lima);
  font-weight: 700;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #4c4c4c;
  text-decoration: none;
  transition: translate 0.5s ease, background-color 0.3s ease;
}

.header-welcome .tp-contact:hover {
  cursor: pointer;
  background-color: var(--ligth-lima);
}

/* Mobile header */
@media (max-width: 820px) {
  .header-welcome h1 {
    font-size: 1.8rem;
    gap: 10px;
  }

  .header-welcome h1 span {
    font-size: 6rem;
  }
}

</style>
