---
import type { LinkType } from '@root/types.d'

interface Props {
  links: LinkType[];
  actualPage: string;
}

const { links, actualPage }: Props = Astro.props;
---
<header class="general-menu">
  <h2 style="margin:0">Agencia MV</h2>
  <nav class="link-menu">
    {
    links.map((link)=> (
      <a class={actualPage === link.src ? 'link-secondary' : 'link-white'} href={link.src}>{link.name}</a>
    ))
    }
    <button class="btn-contact">999-33-44-22</button>
  </nav>
  <div class="burger-menu">
    <div id="burger-up" class="burger"></div>
    <div id="burger-down" class="burger"></div>
  </div>
</header>

<script>
  // Todo este JavaScript se ejecuta de forma nativa en el navegador
  let lastScrollTop = 0;

  const burgerMenu = document.querySelector(".burger-menu");
  const linkMenu = document.querySelector(".link-menu");
  const generalMenu = document.querySelector(".general-menu");

  // 1. Registro de la propiedad CSS animable
  if (CSS.registerProperty) {
    try {
      CSS.registerProperty({
        name: "--grad-pos",
        syntax: "<percentage>",
        inherits: false,
        initialValue: "0%",
      });
    } catch (e) {}
  }

  // 2. Lógica del Menú Burger
  burgerMenu?.addEventListener("click", () => {
    burgerMenu.classList.toggle("active");
    linkMenu?.classList.toggle("active");
    document.body.style.overflow = linkMenu?.classList.contains("active") ? "hidden" : "auto";
  });

  // 3. Lógica de Scroll (Tu animación de subir/bajar)
  window.addEventListener("scroll", () => {
    const st = window.scrollY || document.documentElement.scrollTop;

    if (generalMenu) {
      if (st > lastScrollTop && st > 100) {
        generalMenu.classList.add("goUp");
        generalMenu.classList.remove("down");
      } else {
        generalMenu.classList.add("down");
        generalMenu.classList.remove("goUp");
      }
    }
    lastScrollTop = st;
  });
</script>

<style>
  :host {
    --color-white: #fff;
    --media-query-movile: 820px;
  }

  .general-menu {
    top: 0;
    left: 0;
    color: var(--color-white);
    padding: 30px 35px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: fixed;
    width: 100%;
    box-sizing: border-box;
    background: var(--general-background);
    transition: transform 0.5s ease-out;
    z-index: 200;
    font-size: 1.4rem;
  }

  .general-menu.goUp { transform: translateY(-100%); }
  .general-menu.down { transform: translateY(0); }

  .link-menu {
    display: flex;
    gap: 15px;
    align-items: center;
    transition: all 0.6s ease-in;
  }

  .link-menu .btn-contact {
    --grad-pos: 0%;
    padding: 12px 20px;
    border-radius: 5px;
    text-decoration: none;
    color: var(--formal-white);
    margin-left: 10px;
    font-weight: 700;
    cursor: pointer;
    background: var(--btn-gradient);
    transition: --grad-pos 1s ease, all 0.6s ease;
  }

  .link-menu .btn-contact:hover { --grad-pos: 100%; }

  .link-menu a { text-decoration: none; transition: 0.2s ease }
  .link-menu a:hover { text-decoration: underline; text-underline-offset: 5px; color: var(--color-white); }

  .link-white { color: rgba(214, 214, 214, 0.806);  }

  .link-secondary {   color: var(--color-white);  }


  /* Mobile menu */
  @media (max-width: 820px) {
    .link-menu {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 100vh;
      flex-direction: column;
      background: var(--general-background);
      padding: 50px 20px;
      transform: translateY(-150%);
      gap: 40px;
    }

    .link-menu.active { transform: translateY(0); }

    .burger-menu {
      display: flex;
      flex-direction: column;
      gap: 8px;
      cursor: pointer;
    }

    .burger {
      width: 30px;
      height: 3px;
      background: var(--color-white);
      transition: 0.3s;
    }

    .burger-menu.active #burger-up { transform: translateY(11px) rotate(45deg); }
    .burger-menu.active #burger-down { transform: translateY(0) rotate(-45deg); }
  }

  @media (min-width: 821px) {
    .burger-menu { display: none; }
  }
</style>
