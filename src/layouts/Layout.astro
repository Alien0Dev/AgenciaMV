---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { LinkType } from "../types";
import "../variables.css";
interface Props {
  actualPage: string,
  title: string,
}

const { actualPage, title }: Props = Astro.props;

const links: LinkType[] = [
  { name: "Inicio", src: "/" },
  { name: "Servicios", src: "/services" },
  { name: "Contacto", src: "/contact" }
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
    <title>AgenciaMV · { title }</title>
    <script is:inline src="https://kit.fontawesome.com/50ec7a7a01.js" crossorigin="anonymous"></script>
	</head>
	<body>
    <Header links={links} actualPage={actualPage} />
      <main>
        <slot />
      </main>
    <Footer links={links}/>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
	}

</style>
